  "query": "\n            SELECT\n                order_id,\n                structure_id,\n                price,\n                remaining,\n                virtual_remaining,\n                type_id,\n                is_buy\n            FROM market_order_latest mol\n            WHERE mol.type_id = ANY($1)\n            AND mol.structure_id = ANY($2)\n            ORDER BY mol.price ASC\n        ",
