  "query": "\n            SELECT\n                pj.project_id,\n                pj.type_id,\n                pj.runs,\n                pj.status AS \"status: ProjectJobStatus\",\n                pj.cost,\n                pj.id,\n                pj.job_id,\n                pj.structure_id,\n                pj.character_id,\n                pj.created_at,\n                pj.updated_at,\n                p.name AS project_name,\n                s.name AS structure_name\n            FROM project_job pj\n            JOIN project p ON p.id = pj.project_id\n            JOIN structure s ON s.id = pj.structure_id\n        ",
