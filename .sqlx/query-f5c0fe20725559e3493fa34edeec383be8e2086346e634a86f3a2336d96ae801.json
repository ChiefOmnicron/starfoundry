{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT\n                id,\n                type_id,\n                structure_id,\n                name            AS \"structure_name\",\n                services,\n                rigs,\n                system_id\n            FROM structure\n            WHERE\n                NOT (LOWER(structure.name) LIKE '%' || LOWER($2) || '%') IS FALSE AND\n                NOT (structure.type_id = $3) IS FALSE AND\n                NOT ($4::INTEGER IS NULL OR $4::INTEGER = ANY(services)) IS FALSE AND\n                owner = $1\n            ORDER BY structure.name\n        ",
