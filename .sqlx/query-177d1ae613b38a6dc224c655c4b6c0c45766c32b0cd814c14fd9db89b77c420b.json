  "query": "\n            SELECT\n                ec.character_id,\n                c.corporation_id,\n                ec.domain\n            FROM eve_credential ec\n            JOIN character c ON c.character_id = ec.character_id\n            WHERE\n                scopes && $1::VARCHAR[] AND\n                character_main IS NULL\n        ",
