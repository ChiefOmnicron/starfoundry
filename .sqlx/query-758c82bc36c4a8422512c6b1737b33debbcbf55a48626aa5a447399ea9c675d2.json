{
  "db_name": "PostgreSQL",
  "query": "\n                SELECT\n                    id,\n                    DATE(timestamp) AS \"date!\",\n                    copying,\n                    invention,\n                    manufacturing,\n                    reaction,\n                    research_time,\n                    research_material,\n                    system_id\n                FROM system_index\n                WHERE system_id = $1\n                AND DATE(timestamp) > DATE(NOW() - INTERVAL '7 DAY')\n                AND DATE(timestamp) < DATE(NOW() - INTERVAL '3 DAY')\n            ",
