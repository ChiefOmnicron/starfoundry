  "db_name": "PostgreSQL",
  "query": "\n            SELECT\n                order_id,\n                type_id,\n                structure_id,\n                virtual_remaining\n            FROM market_order_latest mol\n            WHERE mol.type_id = ANY($1)\n            AND mol.structure_id = ANY($2)\n            AND mol.is_buy = false\n            AND virtual_remaining > 0\n            ORDER BY mol.price ASC\n        ",
